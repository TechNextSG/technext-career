<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!--
    Adds a "TechNext Assessment" page to the hr.applicant form view.
    All fields are read-only here — they're written from the candidate
    portal via XML-RPC, not edited by hand inside Odoo. If you do want
    recruiters to override values, remove `readonly="1"` below.
  -->
  <record id="view_hr_applicant_form_tn" model="ir.ui.view">
    <field name="name">hr.applicant.form.tn_assessment</field>
    <field name="model">hr.applicant</field>
    <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
    <field name="arch" type="xml">

      <xpath expr="//notebook" position="inside">
        <page string="TechNext Assessment" name="tn_assessment_page">

          <group string="Profile">
            <field name="x_tn_role" readonly="1"/>
            <field name="x_tn_linkedin" widget="url" readonly="1"/>
            <field name="x_tn_resume_url" widget="url" readonly="1"/>
            <field name="x_tn_last_synced" readonly="1"/>
          </group>

          <group string="DISC + 4-letter Type">
            <group>
              <field name="x_tn_profiler_d_pct" readonly="1"/>
              <field name="x_tn_profiler_i_pct" readonly="1"/>
              <field name="x_tn_profiler_s_pct" readonly="1"/>
              <field name="x_tn_profiler_c_pct" readonly="1"/>
            </group>
            <group>
              <field name="x_tn_profiler_disc_primary" readonly="1"/>
              <field name="x_tn_profiler_disc_secondary" readonly="1"/>
              <field name="x_tn_profiler_mbti" readonly="1"/>
            </group>
          </group>

          <group string="Assessment scores">
            <group>
              <field name="x_tn_company_quiz_pct" readonly="1"/>
              <field name="x_tn_reasoning_pct" readonly="1"/>
            </group>
            <group>
              <field name="x_tn_ai_technical_pct" readonly="1"/>
              <field name="x_tn_fc_technical_pct" readonly="1"/>
              <field name="x_tn_odoo_technical_pct" readonly="1"/>
              <field name="x_tn_cyber_technical_pct" readonly="1"/>
            </group>
          </group>

          <group string="Booking">
            <field name="x_tn_booking_slot" readonly="1"/>
            <div colspan="2" style="background:#fffbeb;border-left:3px solid #f59e0b;padding:6px 10px;font-size:12px">
              <strong>Note:</strong> the booking slot is an expression of interest
              submitted by the candidate. Confirmation is sent separately by
              email or handphone, only to shortlisted candidates.
            </div>
          </group>

        </page>
      </xpath>

    </field>
  </record>

</odoo>
